{
  "id": "hanako-ui-beautify",
  "name": "Hana UI Beautify",
  "version": "0.1.0",
  "description": "Plugin-managed UI beautify pack for official Hanako: HarmonyOS Sans SC fonts and unified motion tokens.",
  "author": "Sun",
  "trust": "full-access",
  "capabilities": {
    "chat": true
  },
  "minAppVersion": "0.293.0",
  "activationEvents": ["onStartup"],
  "contributes": {
    "configuration": {
      "properties": {
        "autoApply": {
          "type": "boolean",
          "title": "Auto apply beautify patch",
          "default": true
        },
        "hanakoInstallDir": {
          "type": "string",
          "title": "Hanako install directory",
          "default": "C:\\Program Files\\Hanako"
        }
      }
    }
  }
}
