{
  "manifestVersion": 1,
  "id": "hanako-ui-beautify",
  "name": "Hana UI Beautify",
  "version": "0.3.3",
  "description": "Hanako 官方客户端美化包：鸿蒙黑体、macOS 风格动效曲线和统一 motion tokens。",
  "author": "Sun",
  "trust": "full-access",
  "capabilities": {
    "chat": true
  },
  "minAppVersion": "0.293.0",
  "activationEvents": ["onStartup"],
  "contributes": {
    "configuration": {
      "properties": {
        "autoApply": {
          "type": "boolean",
          "title": "启动时自动应用美化补丁",
          "default": false
        },
        "strategy": {
          "type": "string",
          "title": "应用策略",
          "enum": ["auto", "runtime", "asar"],
          "default": "auto"
        },
        "probeRuntimeCss": {
          "type": "boolean",
          "title": "探测未公开的运行时 CSS 注入通道",
          "default": false
        },
        "hanakoInstallDir": {
          "type": "string",
          "title": "Hanako 安装目录",
          "default": "C:\\Program Files\\Hanako"
        }
      }
    }
  }
}
